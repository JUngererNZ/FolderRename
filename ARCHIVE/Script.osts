{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n\tlet selectedSheet = workbook.getActiveWorksheet();\r\n\t// Insert copied cells from MB:MB on selectedSheet to MB:MB on selectedSheet.\r\n\tselectedSheet.getRange(\"MB:MB\").insert(ExcelScript.InsertShiftDirection.right);\r\n\tselectedSheet.getRange(\"MB:MB\").copyFrom(selectedSheet.getRange(\"MB:MB\"));\r\n\t// Set visibility of column(s) at range MB:MB on selectedSheet to true\r\n\tselectedSheet.getRange(\"MB:MB\").setColumnHidden(true);\r\n\t// Set range MC1 on selectedSheet\r\n\tselectedSheet.getRange(\"MC1\").setValue(\"COMMENTS 10-03-2026\");\r\n}","description":"","noCodeMetadata":"{\"intents\":[\"Paste copied cells into MB:MB\",\"Hide column(s) on MB:MB\",\"Set cell MC1 to COMMENTS 10-03-2026\"]}","parameterInfo":null,"apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}